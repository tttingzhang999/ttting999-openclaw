// ============================================================
// REFERENCE ONLY — not for direct deployment.
// This file documents gateway-level config flags that can
// reduce verbosity. Adapt to your actual model and runtime.
// ============================================================
//
// OpenClaw Gateway Agent Configuration
// Demonstrates config-level verbosity controls.
// Actual behavior depends on OpenClaw runtime support for these flags.
{
  agents: {
    defaults: {
      model: {
        // Replace with your actual model
        primary: "openai-codex/gpt-5.4",
        fallbacks: [],
      },
      thinkingDefault: "low",
      verboseDefault: "off",       // suppress verbose output globally
      timeoutSeconds: 300,
      contextTokens: 200000,
      maxConcurrent: 3,
    },
    list: [
      {
        id: "example-agent",
        name: "Example",
        workspace: "~/.openclaw/workspace",
        agentDir: "~/.openclaw/agents/example/agent",
        thinkingDefault: "low",
        reasoningDefault: "off",    // hide chain-of-thought from output
        fastModeDefault: true,      // prefer speed over elaboration
        identity: {
          name: "Example",
          theme: "concise assistant",
        },
        tools: {
          profile: "coding",
          allow: ["browser", "bash", "read", "edit", "write", "glob", "grep"],
        },
      },
    ],
  },
}
